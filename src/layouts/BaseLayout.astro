---
import '~/styles/global.css'
import { pricingUrl } from '@chirag127/astro-shell/pricing-url'
import FamilySidebar from '@chirag127/astro-shell/components/FamilySidebar.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Oriz Crypto Tools — Hashes, ciphers, keys. None of it leaves the page.', description = 'MD5 → SHA-3, AES (CBC/GCM/CTR), ChaCha20, RSA, HMAC, bcrypt, certs, CSRs, SSH keypairs.' } = Astro.props
const canonical = new URL(Astro.url.pathname, 'https://crypto.oriz.in').toString()
const pricingHref = pricingUrl('oriz-cipher-crypto-tools-app')
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <header class="site">
      <a class="wordmark" href="/">Crypto</a>
      <nav>
        <a href="/">tools</a>
        <a href="/about/">about</a>
        <a href={pricingHref}>pricing</a>
        <a href="https://account.oriz.in/sign-in">sign in</a>
      </nav>
    </header>
    <div class="oriz-shell">
      <FamilySidebar slug="oriz-cipher-crypto-tools-app" title="Crypto Tools">
        <a slot="tools" href="/tools/hash/">Hashes (MD5 / SHA / etc.)</a>
        <a slot="tools" href="/tools/aes/">AES-CBC / GCM / CTR</a>
        <a slot="tools" href="/tools/chacha20/">ChaCha20</a>
        <a slot="tools" href="/tools/rsa/">RSA generate / encrypt / sign</a>
        <a slot="tools" href="/tools/hmac/">HMAC-SHA256 / 512</a>
        <a slot="tools" href="/tools/bcrypt/">Password hash + verify</a>
        <a slot="tools" href="/tools/uuid/">UUID generator</a>
        <a slot="tools" href="/tools/cert/">X.509 / CSR decoder</a>
        <a slot="tools" href="/tools/ssh-key/">SSH keypair generator</a>
        <a slot="tools" href="/tools/base64/">Base64 encode / decode</a>
        <a slot="tools" href="/tools/urlencode/">URL encode / decode</a>
        <a slot="tools" href="/tools/jwt/">JWT decoder</a>
        <a slot="tools" href="/tools/password/">Password generator</a>
        <a slot="tools" href="/tools/qr/">QR code generator</a>
        <a slot="tools" href="/tools/caesar/">Caesar cipher</a>
        <a slot="tools" href="/tools/rot13/">ROT13</a>
      </FamilySidebar>
      <main id="main" class="oriz-main"><slot /></main>
    </div>
    <footer class="site">
      <span>Oriz Crypto Tools · part of the <a href="https://oriz.in">oriz</a> family · runs in your browser</span>
      <span>
        <a href="/about/">about</a> · <a href="/contact/">contact</a> · <a href="/legal/privacy/">privacy</a> · <a href="/legal/terms/">terms</a> · <a href="/legal/disclaimer/">disclaimer</a>
      </span>
    </footer>
  </body>
</html>
