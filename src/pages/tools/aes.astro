---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="AES-CBC / GCM / CTR — Oriz Crypto Tools" description="AES encrypt and decrypt (CBC, GCM, CTR) — runs in your browser. Part of Oriz Crypto Tools.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">AES-CBC / GCM / CTR</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="tool-ui">
      <div class="row">
        <label for="aes-input">Input (plaintext or ciphertext)</label>
        <textarea id="aes-input" class="io" placeholder="Paste text to encrypt or base64 ciphertext to decrypt…" rows="5"></textarea>
      </div>
      <div class="options-row">
        <div class="opt">
          <label for="aes-key">Key (hex, 32/48/64 chars)</label>
          <input id="aes-key" type="text" class="text-input" placeholder="auto-generate or paste hex key" />
          <button id="aes-genkey" class="btn-sm">Generate Key</button>
        </div>
        <div class="opt">
          <label for="aes-mode">Mode</label>
          <select id="aes-mode" class="select-input">
            <option value="AES-GCM" selected>AES-GCM (authenticated)</option>
            <option value="AES-CBC">AES-CBC</option>
            <option value="AES-CTR">AES-CTR</option>
          </select>
        </div>
      </div>
      <div class="btn-row">
        <button id="aes-encrypt" class="btn">Encrypt</button>
        <button id="aes-decrypt" class="btn btn-sec">Decrypt</button>
      </div>
      <div id="aes-error" class="error-msg" style="display:none;"></div>
      <div class="row">
        <label for="aes-output">Output (base64)</label>
        <textarea id="aes-output" class="io" readonly rows="5" placeholder="Result appears here…"></textarea>
        <button class="btn btn-copy" data-copy="aes-output">Copy</button>
      </div>
      <div class="history-section">
        <p class="hist-label mono">Recent history</p>
        <ul id="aes-history" class="history-list"></ul>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .tool-ui { max-width: 64ch; display: flex; flex-direction: column; gap: 1.25rem; }
  .row { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.8125rem; color: var(--muted); font-family: var(--font-mono); letter-spacing: 0.05em; }
  .io { width: 100%; padding: 0.875rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; resize: vertical; }
  .io:focus { outline: 1px solid var(--accent); }
  .options-row { display: flex; flex-direction: column; gap: 1rem; }
  .opt { display: flex; flex-direction: column; gap: 0.4rem; }
  .text-input { padding: 0.5rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.8125rem; width: 100%; }
  .select-input { padding: 0.4rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; }
  .btn-sm { padding: 0.3rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem; cursor: pointer; align-self: flex-start; margin-top: 0.25rem; }
  .btn-sm:hover { color: var(--ink); }
  .btn-row { display: flex; gap: 0.5rem; }
  .btn { padding: 0.5rem 1.25rem; background: var(--accent); border: none; color: #000; font-family: var(--font-mono); font-size: 0.8125rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { opacity: 0.85; }
  .btn-sec { background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); }
  .btn-copy { margin-top: 0.5rem; align-self: flex-start; padding: 0.4rem 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem; cursor: pointer; }
  .btn-copy:hover { color: var(--ink); }
  .error-msg { color: #f87171; font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.5rem 0.75rem; background: rgba(248,113,113,0.08); border-left: 2px solid #f87171; }
  .hist-label { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .history-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem; }
  .history-list li { font-size: 0.8rem; color: var(--muted); font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer; }
  .history-list li:hover { color: var(--ink); }
</style>

<script>
  const HIST_KEY = 'crypto_aes_hist';
  const MAX_HIST = 5;

  function hexToBytes(hex: string): Uint8Array {
    if (hex.length % 2 !== 0) throw new Error('Odd-length hex string');
    return new Uint8Array(hex.match(/.{2}/g)!.map((b) => parseInt(b, 16)));
  }

  function bytesToHex(bytes: Uint8Array): string {
    return Array.from(bytes).map((b) => b.toString(16).padStart(2, '0')).join('');
  }

  function toBase64(bytes: Uint8Array): string {
    return btoa(String.fromCharCode(...bytes));
  }

  function fromBase64(str: string): Uint8Array {
    return new Uint8Array(atob(str).split('').map((c) => c.charCodeAt(0)));
  }

  async function getKey(hexKey: string, mode: string): Promise<CryptoKey> {
    const keyBytes = hexToBytes(hexKey);
    return crypto.subtle.importKey('raw', keyBytes, { name: mode }, false, ['encrypt', 'decrypt']);
  }

  function loadHistory(): string[] {
    try { return JSON.parse(localStorage.getItem(HIST_KEY) || '[]'); } catch { return []; }
  }

  function saveHistory(item: string) {
    const h = [item, ...loadHistory().filter((x: string) => x !== item)].slice(0, MAX_HIST);
    localStorage.setItem(HIST_KEY, JSON.stringify(h));
    renderHistory();
  }

  function renderHistory() {
    const ul = document.getElementById('aes-history')!;
    ul.innerHTML = '';
    loadHistory().forEach((item: string) => {
      const li = document.createElement('li');
      li.textContent = item;
      li.title = item;
      li.addEventListener('click', () => {
        (document.getElementById('aes-input') as HTMLTextAreaElement).value = item;
      });
      ul.appendChild(li);
    });
  }

  document.getElementById('aes-genkey')!.addEventListener('click', () => {
    const keyBytes = new Uint8Array(32);
    crypto.getRandomValues(keyBytes);
    (document.getElementById('aes-key') as HTMLInputElement).value = bytesToHex(keyBytes);
  });

  async function runAES(mode: 'enc' | 'dec') {
    const errEl = document.getElementById('aes-error')!;
    errEl.style.display = 'none';
    const input = (document.getElementById('aes-input') as HTMLTextAreaElement).value.trim();
    const hexKey = (document.getElementById('aes-key') as HTMLInputElement).value.trim();
    const aesMode = (document.getElementById('aes-mode') as HTMLSelectElement).value;

    if (!hexKey || (hexKey.length !== 32 && hexKey.length !== 48 && hexKey.length !== 64)) {
      errEl.textContent = 'Key must be 32, 48, or 64 hex characters (16/24/32 bytes). Click "Generate Key".';
      errEl.style.display = 'block';
      return;
    }

    try {
      const key = await getKey(hexKey, aesMode);
      if (mode === 'enc') {
        const encoder = new TextEncoder();
        const data = encoder.encode(input);
        let iv: Uint8Array;
        let encrypted: ArrayBuffer;
        let params: AlgorithmIdentifier | AesCbcParams | AesCtrParams | AesGcmParams;

        if (aesMode === 'AES-GCM') {
          iv = new Uint8Array(12);
          crypto.getRandomValues(iv);
          params = { name: 'AES-GCM', iv };
          encrypted = await crypto.subtle.encrypt(params, key, data);
        } else if (aesMode === 'AES-CBC') {
          iv = new Uint8Array(16);
          crypto.getRandomValues(iv);
          params = { name: 'AES-CBC', iv };
          encrypted = await crypto.subtle.encrypt(params, key, data);
        } else {
          iv = new Uint8Array(16);
          crypto.getRandomValues(iv);
          params = { name: 'AES-CTR', counter: iv, length: 64 };
          encrypted = await crypto.subtle.encrypt(params, key, data);
        }

        // Pack: iv + ciphertext as base64
        const combined = new Uint8Array(iv.length + encrypted.byteLength);
        combined.set(iv);
        combined.set(new Uint8Array(encrypted), iv.length);
        (document.getElementById('aes-output') as HTMLTextAreaElement).value = toBase64(combined);
        if (input) saveHistory(input.slice(0, 80));
      } else {
        const combined = fromBase64(input);
        const ivLen = aesMode === 'AES-GCM' ? 12 : 16;
        const iv = combined.slice(0, ivLen);
        const cipherBytes = combined.slice(ivLen);
        let params: AesCbcParams | AesCtrParams | AesGcmParams;

        if (aesMode === 'AES-GCM') {
          params = { name: 'AES-GCM', iv };
        } else if (aesMode === 'AES-CBC') {
          params = { name: 'AES-CBC', iv };
        } else {
          params = { name: 'AES-CTR', counter: iv, length: 64 };
        }
        const decrypted = await crypto.subtle.decrypt(params, key, cipherBytes);
        (document.getElementById('aes-output') as HTMLTextAreaElement).value = new TextDecoder().decode(decrypted);
        if (input) saveHistory(input.slice(0, 80));
      }
    } catch (e) {
      errEl.textContent = (mode === 'enc' ? 'Encryption' : 'Decryption') + ' failed: ' + (e as Error).message;
      errEl.style.display = 'block';
    }
  }

  document.getElementById('aes-encrypt')!.addEventListener('click', () => runAES('enc'));
  document.getElementById('aes-decrypt')!.addEventListener('click', () => runAES('dec'));

  document.querySelectorAll('.btn-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLButtonElement).dataset.copy!;
      const val = (document.getElementById(id) as HTMLTextAreaElement).value;
      navigator.clipboard.writeText(val).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  });

  renderHistory();
</script>
