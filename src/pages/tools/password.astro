---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="Random Password Generator — Oriz Crypto Tools" description="Generate strong random passwords — runs in your browser. Part of Oriz Crypto Tools.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">Password Generator</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="tool-ui">
      <div class="options-grid">
        <div class="opt-row">
          <label for="pwd-length">Length</label>
          <input id="pwd-length" type="number" min="4" max="128" value="20" class="num-input" />
        </div>
        <div class="opt-row">
          <label><input id="pwd-upper" type="checkbox" checked /> Uppercase (A-Z)</label>
        </div>
        <div class="opt-row">
          <label><input id="pwd-lower" type="checkbox" checked /> Lowercase (a-z)</label>
        </div>
        <div class="opt-row">
          <label><input id="pwd-digits" type="checkbox" checked /> Digits (0-9)</label>
        </div>
        <div class="opt-row">
          <label><input id="pwd-symbols" type="checkbox" checked /> Symbols (!@#$%^&*)</label>
        </div>
        <div class="opt-row">
          <label><input id="pwd-exclude-ambiguous" type="checkbox" /> Exclude ambiguous (0O1lI|)</label>
        </div>
      </div>
      <div class="btn-row">
        <button id="pwd-generate" class="btn">Generate</button>
        <button id="pwd-generate-bulk" class="btn btn-sec">Generate 5</button>
      </div>
      <div id="pwd-error" class="error-msg" style="display:none;"></div>
      <div class="row">
        <label for="pwd-output">Generated Password</label>
        <textarea id="pwd-output" class="io" readonly rows="3" placeholder="Password appears here…"></textarea>
        <button class="btn btn-copy" data-copy="pwd-output">Copy</button>
      </div>
      <div class="history-section">
        <p class="hist-label mono">Recent history</p>
        <ul id="pwd-history" class="history-list"></ul>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .tool-ui { max-width: 64ch; display: flex; flex-direction: column; gap: 1.25rem; }
  .row { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.8125rem; color: var(--muted); font-family: var(--font-mono); letter-spacing: 0.05em; display: flex; align-items: center; gap: 0.5rem; }
  .io { width: 100%; padding: 0.875rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; resize: vertical; }
  .io:focus { outline: 1px solid var(--accent); }
  .options-grid { display: flex; flex-direction: column; gap: 0.6rem; }
  .opt-row { display: flex; align-items: center; gap: 0.75rem; }
  .opt-row label { color: var(--ink); }
  input[type="checkbox"] { accent-color: var(--accent); width: 1rem; height: 1rem; }
  .num-input { padding: 0.4rem 0.75rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; width: 5rem; }
  .btn-row { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .btn { padding: 0.5rem 1.25rem; background: var(--accent); border: none; color: #000; font-family: var(--font-mono); font-size: 0.8125rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { opacity: 0.85; }
  .btn-sec { background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); }
  .btn-copy { margin-top: 0.5rem; align-self: flex-start; padding: 0.4rem 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem; cursor: pointer; }
  .btn-copy:hover { color: var(--ink); }
  .error-msg { color: #f87171; font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.5rem 0.75rem; background: rgba(248,113,113,0.08); border-left: 2px solid #f87171; }
  .hist-label { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .history-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem; }
  .history-list li { font-size: 0.8rem; color: var(--muted); font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer; }
  .history-list li:hover { color: var(--ink); }
</style>

<script>
  const HIST_KEY = 'crypto_pwd_hist';
  const MAX_HIST = 5;

  function generatePassword(length: number, upper: boolean, lower: boolean, digits: boolean, symbols: boolean, excludeAmbiguous: boolean): string {
    let charset = '';
    if (upper) charset += excludeAmbiguous ? 'ABCDEFGHJKLMNPQRSTUVWXYZ' : 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
    if (lower) charset += excludeAmbiguous ? 'abcdefghjkmnpqrstuvwxyz' : 'abcdefghijklmnopqrstuvwxyz';
    if (digits) charset += excludeAmbiguous ? '23456789' : '0123456789';
    if (symbols) charset += '!@#$%^&*()-_=+[]{}|;:,.<>?';
    if (!charset) return '';

    const array = new Uint32Array(length);
    crypto.getRandomValues(array);
    return Array.from(array, (val) => charset[val % charset.length]).join('');
  }

  function loadHistory(): string[] {
    try { return JSON.parse(localStorage.getItem(HIST_KEY) || '[]'); } catch { return []; }
  }

  function saveHistory(item: string) {
    const h = [item, ...loadHistory().filter((x: string) => x !== item)].slice(0, MAX_HIST);
    localStorage.setItem(HIST_KEY, JSON.stringify(h));
    renderHistory();
  }

  function renderHistory() {
    const ul = document.getElementById('pwd-history')!;
    ul.innerHTML = '';
    loadHistory().forEach((item: string) => {
      const li = document.createElement('li');
      li.textContent = item;
      li.title = item;
      li.addEventListener('click', () => {
        (document.getElementById('pwd-output') as HTMLTextAreaElement).value = item;
      });
      ul.appendChild(li);
    });
  }

  function getOptions() {
    const length = parseInt((document.getElementById('pwd-length') as HTMLInputElement).value, 10) || 20;
    const upper = (document.getElementById('pwd-upper') as HTMLInputElement).checked;
    const lower = (document.getElementById('pwd-lower') as HTMLInputElement).checked;
    const digits = (document.getElementById('pwd-digits') as HTMLInputElement).checked;
    const symbols = (document.getElementById('pwd-symbols') as HTMLInputElement).checked;
    const excludeAmbiguous = (document.getElementById('pwd-exclude-ambiguous') as HTMLInputElement).checked;
    return { length, upper, lower, digits, symbols, excludeAmbiguous };
  }

  document.getElementById('pwd-generate')!.addEventListener('click', () => {
    const errEl = document.getElementById('pwd-error')!;
    errEl.style.display = 'none';
    const { length, upper, lower, digits, symbols, excludeAmbiguous } = getOptions();
    if (!upper && !lower && !digits && !symbols) {
      errEl.textContent = 'Select at least one character set.';
      errEl.style.display = 'block';
      return;
    }
    const pwd = generatePassword(length, upper, lower, digits, symbols, excludeAmbiguous);
    (document.getElementById('pwd-output') as HTMLTextAreaElement).value = pwd;
    saveHistory(pwd);
  });

  document.getElementById('pwd-generate-bulk')!.addEventListener('click', () => {
    const errEl = document.getElementById('pwd-error')!;
    errEl.style.display = 'none';
    const { length, upper, lower, digits, symbols, excludeAmbiguous } = getOptions();
    if (!upper && !lower && !digits && !symbols) {
      errEl.textContent = 'Select at least one character set.';
      errEl.style.display = 'block';
      return;
    }
    const pwds = Array.from({ length: 5 }, () => generatePassword(length, upper, lower, digits, symbols, excludeAmbiguous));
    (document.getElementById('pwd-output') as HTMLTextAreaElement).value = pwds.join('\n');
    pwds.forEach((p) => saveHistory(p));
  });

  document.querySelectorAll('.btn-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLButtonElement).dataset.copy!;
      const val = (document.getElementById(id) as HTMLTextAreaElement).value;
      navigator.clipboard.writeText(val).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  });

  renderHistory();
</script>
