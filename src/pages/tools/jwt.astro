---
import BaseLayout from '~/layouts/BaseLayout.astro'
---
<BaseLayout title="JWT Decode — Oriz Crypto Tools" description="Decode and inspect JWT tokens (header, payload, signature) — runs in your browser. Part of Oriz Crypto Tools.">
  <article class="tool">
    <p class="back mono"><a href="/">← all tools</a></p>
    <h1 class="h1">JWT Decode</h1>
    <p class="status mono ready">ready · v0.1</p>

    <div class="tool-ui">
      <div class="row">
        <label for="jwt-input">JWT Token</label>
        <textarea id="jwt-input" class="io" placeholder="Paste your JWT here…" rows="4"></textarea>
      </div>
      <div class="btn-row">
        <button id="jwt-decode" class="btn">Decode</button>
      </div>
      <div id="jwt-error" class="error-msg" style="display:none;"></div>
      <div id="jwt-result" style="display:none;">
        <div class="section">
          <p class="sect-label mono">Header</p>
          <textarea id="jwt-header" class="io" readonly rows="5"></textarea>
          <button class="btn btn-copy" data-copy="jwt-header">Copy</button>
        </div>
        <div class="section">
          <p class="sect-label mono">Payload</p>
          <textarea id="jwt-payload" class="io" readonly rows="8"></textarea>
          <button class="btn btn-copy" data-copy="jwt-payload">Copy</button>
        </div>
        <div class="section">
          <p class="sect-label mono">Signature (base64url)</p>
          <textarea id="jwt-signature" class="io" readonly rows="2"></textarea>
          <button class="btn btn-copy" data-copy="jwt-signature">Copy</button>
        </div>
        <div id="jwt-expiry" class="expiry-block"></div>
      </div>
      <div class="history-section">
        <p class="hist-label mono">Recent history</p>
        <ul id="jwt-history" class="history-list"></ul>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .tool { padding-block: 0 2rem; }
  .back { font-size: 12px; margin: 0 0 2rem; }
  .back a { color: var(--muted); text-decoration: none; }
  .back a:hover { color: var(--ink); }
  .h1 { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.75rem, 4vw, 2.5rem); margin: 0 0 0.5rem; line-height: 1.1; }
  .status { font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; margin: 0 0 2rem; }
  .status.ready { color: var(--accent); }
  .tool-ui { max-width: 64ch; display: flex; flex-direction: column; gap: 1.25rem; }
  .row { display: flex; flex-direction: column; gap: 0.4rem; }
  label { font-size: 0.8125rem; color: var(--muted); font-family: var(--font-mono); letter-spacing: 0.05em; }
  .io { width: 100%; padding: 0.875rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--ink); font-family: var(--font-mono); font-size: 0.875rem; resize: vertical; }
  .io:focus { outline: 1px solid var(--accent); }
  .btn-row { display: flex; gap: 0.5rem; }
  .btn { padding: 0.5rem 1.25rem; background: var(--accent); border: none; color: #000; font-family: var(--font-mono); font-size: 0.8125rem; cursor: pointer; letter-spacing: 0.04em; }
  .btn:hover { opacity: 0.85; }
  .btn-copy { margin-top: 0.5rem; align-self: flex-start; padding: 0.4rem 0.875rem; background: var(--paper-2); border: 1px solid var(--rule); color: var(--muted); font-family: var(--font-mono); font-size: 0.75rem; cursor: pointer; }
  .btn-copy:hover { color: var(--ink); }
  .error-msg { color: #f87171; font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.5rem 0.75rem; background: rgba(248,113,113,0.08); border-left: 2px solid #f87171; }
  .section { display: flex; flex-direction: column; gap: 0.4rem; }
  .sect-label { font-size: 11px; color: var(--accent); letter-spacing: 0.1em; text-transform: uppercase; margin: 0; font-family: var(--font-mono); }
  .expiry-block { font-family: var(--font-mono); font-size: 0.8125rem; padding: 0.75rem 1rem; background: var(--paper-2); border: 1px solid var(--rule); }
  .expiry-block.expired { border-color: #f87171; color: #f87171; }
  .expiry-block.valid { border-color: var(--accent); color: var(--accent); }
  #jwt-result { display: flex; flex-direction: column; gap: 1.25rem; }
  .hist-label { font-size: 11px; color: var(--muted); letter-spacing: 0.08em; text-transform: uppercase; margin: 0 0 0.5rem; }
  .history-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 0.25rem; }
  .history-list li { font-size: 0.8rem; color: var(--muted); font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: pointer; }
  .history-list li:hover { color: var(--ink); }
</style>

<script>
  const HIST_KEY = 'crypto_jwt_hist';
  const MAX_HIST = 5;

  function base64urlDecode(str: string): string {
    const padded = str.replace(/-/g, '+').replace(/_/g, '/');
    const pad = padded.length % 4;
    const withPad = pad ? padded + '===='.slice(pad) : padded;
    return decodeURIComponent(escape(atob(withPad)));
  }

  function loadHistory(): string[] {
    try { return JSON.parse(localStorage.getItem(HIST_KEY) || '[]'); } catch { return []; }
  }

  function saveHistory(item: string) {
    const h = [item, ...loadHistory().filter((x: string) => x !== item)].slice(0, MAX_HIST);
    localStorage.setItem(HIST_KEY, JSON.stringify(h));
    renderHistory();
  }

  function renderHistory() {
    const ul = document.getElementById('jwt-history')!;
    ul.innerHTML = '';
    loadHistory().forEach((item: string) => {
      const li = document.createElement('li');
      li.textContent = item.slice(0, 60) + (item.length > 60 ? '…' : '');
      li.title = item;
      li.addEventListener('click', () => {
        (document.getElementById('jwt-input') as HTMLTextAreaElement).value = item;
      });
      ul.appendChild(li);
    });
  }

  document.getElementById('jwt-decode')!.addEventListener('click', () => {
    const errEl = document.getElementById('jwt-error')!;
    const resultEl = document.getElementById('jwt-result')!;
    errEl.style.display = 'none';
    resultEl.style.display = 'none';

    const token = (document.getElementById('jwt-input') as HTMLTextAreaElement).value.trim();
    const parts = token.split('.');
    if (parts.length !== 3) {
      errEl.textContent = 'Invalid JWT — expected 3 dot-separated parts.';
      errEl.style.display = 'block';
      return;
    }

    try {
      const header = JSON.parse(base64urlDecode(parts[0]));
      const payload = JSON.parse(base64urlDecode(parts[1]));

      (document.getElementById('jwt-header') as HTMLTextAreaElement).value = JSON.stringify(header, null, 2);
      (document.getElementById('jwt-payload') as HTMLTextAreaElement).value = JSON.stringify(payload, null, 2);
      (document.getElementById('jwt-signature') as HTMLTextAreaElement).value = parts[2];

      // Expiry check
      const expiryEl = document.getElementById('jwt-expiry')!;
      if (payload.exp) {
        const expDate = new Date(payload.exp * 1000);
        const now = new Date();
        if (expDate < now) {
          expiryEl.textContent = `Expired: ${expDate.toISOString()} (${Math.round((now.getTime() - expDate.getTime()) / 1000 / 60)} min ago)`;
          expiryEl.className = 'expiry-block expired';
        } else {
          expiryEl.textContent = `Valid until: ${expDate.toISOString()} (${Math.round((expDate.getTime() - now.getTime()) / 1000 / 60)} min remaining)`;
          expiryEl.className = 'expiry-block valid';
        }
        expiryEl.style.display = 'block';
      } else {
        expiryEl.style.display = 'none';
      }

      resultEl.style.display = 'flex';
      saveHistory(token);
    } catch (e) {
      errEl.textContent = 'Decode failed: ' + (e as Error).message;
      errEl.style.display = 'block';
    }
  });

  document.querySelectorAll('.btn-copy').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = (btn as HTMLButtonElement).dataset.copy!;
      const val = (document.getElementById(id) as HTMLTextAreaElement).value;
      navigator.clipboard.writeText(val).then(() => {
        btn.textContent = 'Copied!';
        setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
      });
    });
  });

  renderHistory();
</script>
